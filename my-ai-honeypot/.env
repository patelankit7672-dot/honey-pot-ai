# ════════════════════════════════════════════════
#   HONEY.AI — Environment Configuration
# ════════════════════════════════════════════════

# ── Ollama (Primary — Local AI, no API key needed) ───────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=honeypot-qwen

# ── Groq API (Optional cloud fallback) ──────────────────────────
GROQ_API_KEY=paste_your_key_here

# ── Daily Email Report (Gmail App Password required) ────────────
# To get an App Password: myaccount.google.com → Security → 2FA → App Passwords
SMTP_EMAIL=your-honeypot-bot@gmail.com
SMTP_PASSWORD=your-gmail-app-password
